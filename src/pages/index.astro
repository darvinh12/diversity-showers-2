---
import Layout from "../layouts/Layout.astro";
import Reveal from "../components/Reveal.astro";
import HeroSlider from "../components/HeroSlider.tsx";
import ProductCard from "../components/ProductCard.astro";
import { site } from "../lib/site";
import { products } from "../data/products";
import { testimonials } from "../data/testimonials";

const stats = [
  { value: "180+", label: "Current Clients" },
  { value: "15+", label: "Years of Experience" },
  { value: "99%", label: "Satisfied Customers" },
];

const offer = [
  {
    title: "Frameless Shower Doors",
    href: "/services/frameless-shower-doors",
    desc: "Custom tempered-glass doors that add a touch of luxury to any bathroom.",
    icon: "door",
  },
  {
    title: "Wall Mirrors",
    href: "/services/wall-mirrors",
    desc: "Custom mirrors that make spaces brighter and more spacious.",
    icon: "mirror",
  },
  {
    title: "Glass Railing Systems",
    href: "/services/glass-railing-systems",
    desc: "The largest selection of glass railings in North Texas.",
    icon: "railing",
  },
];

const secondaryServices = [
  { title: "Framed Shower Doors", href: "/services/framed-shower-doors" },
  { title: "Commercial Entry Doors", href: "/services/commercial-entry-doors" },
  {
    title: "Office Glass Partitions",
    href: "/services/office-glass-partitions-and-commercial-glass",
  },
];

const process = [
  {
    n: "01",
    title: "Crafting Innovative Concepts",
    desc: "We merge cutting-edge glass technology with functional design to offer solutions that inspire and elevate.",
  },
  {
    n: "02",
    title: "Tailored Budget Planning",
    desc: "Customized plans that align with your goals and resources — optimizing cost without sacrificing quality.",
  },
  {
    n: "03",
    title: "Flawless Design Execution",
    desc: "From premium materials to precision installation, every step is carried out to perfection.",
  },
  {
    n: "04",
    title: "Turning Glass Dreams into Reality",
    desc: "A collaborative, transparent process built to exceed your expectations.",
  },
];

const featured = products.filter((p) =>
  ["DR037", "DP8", "DRC01", "CATALINA"].includes(p.code),
);

const homeTestimonials = testimonials.slice(0, 3);
---

<Layout active="home">
  <!-- ============ HERO (autoplay slider) ============ -->
  <section class="relative isolate flex h-[100svh] min-h-[560px] items-center overflow-hidden pt-20">
    <HeroSlider client:load />

    <div class="mx-auto w-full max-w-[1280px] px-5 py-10 md:px-10">
      <div class="max-w-2xl">
        <span class="eyebrow eyebrow--bone">Welcome to Diversity Showers</span>
        <h1 class="mt-5 text-[clamp(2.25rem,6vw,4.5rem)] font-bold leading-[1.04] tracking-[-0.04em] text-[var(--color-bone)]">
          Where we redefine the possibilities of glass
        </h1>
        <p class="mt-5 max-w-lg text-base leading-relaxed text-[var(--color-bone-muted)] md:text-lg">
          Custom frameless shower doors, mirrors and glass railings — made in
          Carrollton, Texas.
        </p>
        <div class="mt-7 flex flex-col gap-3 sm:flex-row">
          <a href="/portfolio" class="btn btn-primary">View our work</a>
          <a href="/contact" class="btn btn-ghost-dark">Get a quote</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ STATS BAR ============ -->
  <section class="border-b border-[var(--color-chrome)] bg-[var(--color-light)]">
    <div class="mx-auto grid max-w-[1280px] grid-cols-1 divide-y divide-[var(--color-chrome)] px-5 sm:grid-cols-3 sm:divide-x sm:divide-y-0 md:px-10">
      {
        stats.map((s) => (
          <div class="reveal flex flex-col items-start gap-1 py-8 sm:items-center sm:py-10" data-reveal-group="stats">
            <span class="text-4xl font-bold tracking-[-0.03em] text-[var(--color-ink)] md:text-5xl">
              {s.value}
            </span>
            <span class="text-sm text-[var(--color-ink-muted)]">{s.label}</span>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ============ ABOUT ============ -->
  <section class="bg-[var(--color-light)] py-24 md:py-32">
    <div class="mx-auto grid max-w-[1280px] grid-cols-1 items-center gap-12 px-5 md:px-10 lg:grid-cols-[1fr_0.85fr] lg:gap-20">
      <div class="reveal">
        <span class="eyebrow eyebrow--muted">[ About Diversity Showers ]</span>
        <h2 class="mt-5 text-[clamp(1.75rem,4vw,3rem)] font-bold leading-[1.08] tracking-[-0.03em] text-[var(--color-ink)]">
          Transforming bathrooms with innovation and style
        </h2>
        <p class="mt-6 max-w-xl text-base leading-relaxed text-[var(--color-ink-muted)] md:text-lg">
          At Diversity Showers, we are committed to redefining the standards of the
          shower glass industry. We create unique, aesthetically stunning glass
          solutions for every client — whether you have a clear vision or need help
          shaping your ideas.
        </p>
        <a href="/portfolio" class="mt-8 inline-flex items-center gap-2 font-semibold text-[var(--color-water)] transition-colors hover:text-[var(--color-water-deep)]">
          View portfolio
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" /></svg>
        </a>
      </div>

      <div class="reveal overflow-hidden rounded-[var(--radius-card)] border border-[var(--color-chrome)]">
        <img
          src="/images/paginas/servicios/shower-box-scaled.webp"
          alt="Frameless glass shower with a chrome handle catching light"
          loading="lazy"
          decoding="async"
          class="aspect-[4/5] w-full object-cover"
        />
      </div>
    </div>
  </section>

  <!-- ============ SERVICES (charcoal) ============ -->
  <section class="on-dark bg-[var(--color-charcoal)] py-24 text-[var(--color-bone)] md:py-32">
    <div class="mx-auto max-w-[1280px] px-5 md:px-10">
      <div class="reveal max-w-2xl">
        <span class="eyebrow">[ Our Services ]</span>
        <h2 class="mt-5 text-[clamp(1.75rem,4vw,3rem)] font-bold leading-[1.08] tracking-[-0.03em]">
          What we can offer
        </h2>
      </div>

      <div class="mt-14 grid grid-cols-1 gap-5 md:grid-cols-3">
        {
          offer.map((s) => (
            <a
              href={s.href}
              class="reveal group flex flex-col rounded-[var(--radius-card)] border border-white/10 bg-[var(--color-charcoal-2)] p-8 transition-colors duration-200 hover:border-[var(--color-water)]"
              data-reveal-group="offer"
            >
              <span class="inline-flex h-12 w-12 items-center justify-center rounded-full border border-white/15 text-[var(--color-water)] transition-colors group-hover:border-[var(--color-water)]">
                {s.icon === "door" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="3" width="12" height="18" rx="1" /><circle cx="14" cy="12" r="0.8" fill="currentColor" /></svg>
                )}
                {s.icon === "mirror" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="2" width="12" height="20" rx="6" /><line x1="9" y1="6" x2="9" y2="10" /></svg>
                )}
                {s.icon === "railing" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6" /><line x1="5" y1="6" x2="5" y2="20" /><line x1="12" y1="6" x2="12" y2="20" /><line x1="19" y1="6" x2="19" y2="20" /></svg>
                )}
              </span>
              <h3 class="mt-6 text-xl font-semibold tracking-[-0.01em]">{s.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-[var(--color-bone-muted)]">{s.desc}</p>
              <span class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-water)]">
                Learn more
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" /></svg>
              </span>
            </a>
          ))
        }
      </div>

      <div class="reveal mt-6 flex flex-wrap gap-3">
        {
          secondaryServices.map((s) => (
            <a
              href={s.href}
              class="inline-flex min-h-[44px] items-center rounded-full border border-white/15 px-5 text-sm text-[var(--color-bone-muted)] transition-colors hover:border-[var(--color-water)] hover:text-[var(--color-bone)]"
            >
              {s.title}
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ PORTFOLIO ============ -->
  <section class="bg-[var(--color-light)] py-24 md:py-32">
    <div class="mx-auto max-w-[1280px] px-5 md:px-10">
      <div class="reveal flex flex-wrap items-end justify-between gap-6">
        <div class="max-w-2xl">
          <span class="eyebrow eyebrow--muted">[ Our Portfolio ]</span>
          <h2 class="mt-5 text-[clamp(1.75rem,4vw,3rem)] font-bold leading-[1.08] tracking-[-0.03em] text-[var(--color-ink)]">
            Give a special touch to your bathroom
          </h2>
        </div>
        <a href="/portfolio" class="btn btn-ghost">View full catalog</a>
      </div>

      <div class="mt-14 grid grid-cols-2 gap-5 lg:grid-cols-4">
        {featured.map((p) => <ProductCard product={p} group="featured" />)}
      </div>
    </div>
  </section>

  <!-- ============ PROCESS (charcoal) ============ -->
  <section class="on-dark bg-[var(--color-charcoal)] py-24 text-[var(--color-bone)] md:py-32">
    <div class="mx-auto max-w-[1280px] px-5 md:px-10">
      <div class="reveal max-w-2xl">
        <span class="eyebrow">[ Our Creative Process ]</span>
        <h2 class="mt-5 text-[clamp(1.75rem,4vw,3rem)] font-bold leading-[1.08] tracking-[-0.03em]">
          Efficient steps towards excellence
        </h2>
      </div>

      <div class="mt-14 grid grid-cols-1 gap-px overflow-hidden rounded-[var(--radius-card)] border border-white/10 bg-white/10 sm:grid-cols-2 lg:grid-cols-4">
        {
          process.map((step) => (
            <div class="reveal flex flex-col bg-[var(--color-charcoal)] p-7" data-reveal-group="process">
              <span class="code text-[var(--color-water)]">{step.n}</span>
              <h3 class="mt-4 text-lg font-semibold leading-snug tracking-[-0.01em]">{step.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-[var(--color-bone-muted)]">{step.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ TESTIMONIALS ============ -->
  <section class="bg-[var(--color-light)] py-24 md:py-32">
    <div class="mx-auto max-w-[1280px] px-5 md:px-10">
      <div class="reveal max-w-2xl">
        <span class="eyebrow eyebrow--muted">[ Testimonials ]</span>
        <h2 class="mt-5 text-[clamp(1.75rem,4vw,3rem)] font-bold leading-[1.08] tracking-[-0.03em] text-[var(--color-ink)]">
          What people say
        </h2>
      </div>

      <div class="mt-14 grid grid-cols-1 gap-5 md:grid-cols-3">
        {
          homeTestimonials.map((t) => (
            <figure class="reveal flex flex-col rounded-[var(--radius-card)] border border-[var(--color-chrome)] bg-white p-8" data-reveal-group="testimonials">
              <svg class="text-[var(--color-chrome)]" width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M9.5 7C6.5 7 5 9 5 12v5h5v-5H7.5c0-1.5.7-2.5 2-3V7zm9 0c-3 0-4.5 2-4.5 5v5h5v-5H16c0-1.5.7-2.5 2-3V7z" /></svg>
              <blockquote class="mt-5 flex-1 text-[15px] leading-relaxed text-[var(--color-ink)]">
                "{t.quote}"
              </blockquote>
              <figcaption class="mt-6 border-t border-[var(--color-chrome)] pt-4">
                <span class="block text-sm font-semibold text-[var(--color-ink)]">{t.author}</span>
                {t.location && <span class="code text-[var(--color-ink-muted)]">{t.location}</span>}
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ FINAL CTA (charcoal) ============ -->
  <section class="on-dark bg-[var(--color-charcoal)] py-24 text-[var(--color-bone)] md:py-32">
    <div class="mx-auto max-w-[1280px] px-5 md:px-10">
      <div class="reveal max-w-2xl">
        <span class="eyebrow">[ Get in Touch ]</span>
        <h2 class="mt-5 text-[clamp(2rem,5vw,3.5rem)] font-bold leading-[1.05] tracking-[-0.03em]">
          Let's start a project
        </h2>
        <p class="mt-5 max-w-lg text-base leading-relaxed text-[var(--color-bone-muted)] md:text-lg">
          Give us a call or drop by anytime — we answer all enquiries within 24 hours
          on business days.
        </p>
        <a href="/contact" class="btn btn-primary mt-8">Start a project</a>
      </div>

      <div class="reveal mt-14 grid grid-cols-1 gap-px overflow-hidden rounded-[var(--radius-card)] border border-white/10 bg-white/10 sm:grid-cols-2 lg:grid-cols-4">
        {
          [
            { label: "Our Address", value: site.address.full },
            { label: "Our Mailbox", value: site.email, href: `mailto:${site.email}` },
            { label: "Office", value: site.phones.office, href: `tel:${site.phones.office.replace(/\s/g, "")}` },
            { label: "Cell", value: site.phones.cell, href: `tel:${site.phones.cell.replace(/\s/g, "")}` },
          ].map((c) => (
            <div class="bg-[var(--color-charcoal)] p-6">
              <span class="eyebrow eyebrow--bone">{c.label}</span>
              {c.href ? (
                <a href={c.href} class="mt-3 block text-sm leading-relaxed text-[var(--color-bone)] transition-colors hover:text-[var(--color-water)]">{c.value}</a>
              ) : (
                <p class="mt-3 text-sm leading-relaxed text-[var(--color-bone)]">{c.value}</p>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <Reveal />
</Layout>
