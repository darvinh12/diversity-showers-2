---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import Reveal from "../components/Reveal.astro";
import { faqs, FAQ_TOPICS } from "../data/faqs";
---

<Layout
  active="faq"
  title="FAQ — Diversity Showers"
  description="Answers about our glass products, ordering, custom orders, materials, payment, hours and showroom location."
>
  <PageHero
    eyebrow="[ FAQ ]"
    title="Frequently asked questions"
    lead="Clear, helpful information about our glass and shower remodeling services — our process, materials, timelines, warranties and custom solutions. Our goal is to make your experience simple, transparent and worry-free."
  />

  <section class="bg-[var(--color-light)] py-16 md:py-24">
    <div class="mx-auto grid max-w-[1280px] grid-cols-1 gap-10 px-5 md:px-10 lg:grid-cols-[220px_1fr] lg:gap-16">
      <!-- Topic index -->
      <aside class="lg:sticky lg:top-28 lg:self-start">
        <span class="eyebrow eyebrow--muted">Filter by topic</span>
        <div class="mt-4 flex flex-wrap gap-2 lg:flex-col lg:items-start lg:gap-1">
          {
            FAQ_TOPICS.map((t, i) => (
              <button
                type="button"
                data-topic={t}
                class:list={[
                  "topic-btn inline-flex min-h-[40px] items-center rounded-full px-4 text-sm transition-colors lg:rounded-md lg:px-3 lg:py-1.5",
                  i === 0
                    ? "bg-[var(--color-ink)] text-white"
                    : "text-[var(--color-ink-muted)] hover:bg-[var(--color-glass)] hover:text-[var(--color-ink)]",
                ]}
              >
                {t}
              </button>
            ))
          }
        </div>
      </aside>

      <!-- Accordion -->
      <div class="flex flex-col gap-3" id="faq-list">
        {
          faqs.map((faq, i) => (
            <details
              class="faq-item reveal group rounded-[var(--radius-card)] border border-[var(--color-chrome)] bg-white"
              data-topic={faq.topic ?? "Other"}
              data-reveal-group="faq"
              open={i === 0}
            >
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 text-[var(--color-ink)] [&::-webkit-details-marker]:hidden">
                <span class="text-base font-medium leading-snug">{faq.question}</span>
                <svg
                  class="shrink-0 text-[var(--color-ink-muted)] transition-transform duration-300 group-open:rotate-180"
                  width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
                ><polyline points="6 9 12 15 18 9" /></svg>
              </summary>
              <div class="px-6 pb-6 text-sm leading-relaxed text-[var(--color-ink-muted)]">
                {faq.answer}
              </div>
            </details>
          ))
        }
        <p class="mt-4 hidden text-center text-[var(--color-ink-muted)]" id="faq-empty">
          No questions in this topic.
        </p>
      </div>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="on-dark bg-[var(--color-charcoal)] py-20 text-[var(--color-bone)] md:py-24">
    <div class="mx-auto max-w-[1280px] px-5 text-center md:px-10">
      <span class="eyebrow">[ Still have questions? ]</span>
      <h2 class="reveal mx-auto mt-5 max-w-2xl text-[clamp(1.75rem,4vw,2.75rem)] font-bold leading-[1.1] tracking-[-0.03em]">
        Our specialists are ready to help
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-[var(--color-bone-muted)]">
        Our team will review your project and give you personalized guidance.
      </p>
      <a href="/contact" class="btn btn-primary mt-8">Contact our team</a>
    </div>
  </section>

  <Reveal />

  <script>
    const topicBtns = document.querySelectorAll<HTMLButtonElement>(".topic-btn");
    const items = Array.from(document.querySelectorAll<HTMLElement>(".faq-item"));
    const empty = document.getElementById("faq-empty");

    const active = ["bg-[var(--color-ink)]", "text-white"];
    const idle = ["text-[var(--color-ink-muted)]"];

    topicBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const topic = btn.dataset.topic;

        topicBtns.forEach((b) => {
          active.forEach((c) => b.classList.remove(c));
          idle.forEach((c) => b.classList.add(c));
        });
        idle.forEach((c) => btn.classList.remove(c));
        active.forEach((c) => btn.classList.add(c));

        let shown = 0;
        items.forEach((item) => {
          const match = topic === "All" || item.dataset.topic === topic;
          item.style.display = match ? "" : "none";
          if (match) shown++;
        });
        if (empty) empty.classList.toggle("hidden", shown > 0);
      });
    });
  </script>
</Layout>
