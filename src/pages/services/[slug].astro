---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import Reveal from "../../components/Reveal.astro";
import { services } from "../../data/services";
import { serviceImage } from "../../lib/service-images";

export function getStaticPaths() {
  return services.map((s) => ({ params: { slug: s.slug }, props: { service: s } }));
}

const { service } = Astro.props;
const others = services.filter((s) => s.slug !== service.slug).slice(0, 4);
---

<Layout
  active="services"
  title={`${service.title} — Diversity Showers`}
  description={service.short}
>
  <PageHero eyebrow="[ Our Services ]" title={service.title} lead={service.subtitle} />

  <section class="bg-[var(--color-light)] py-20 md:py-28">
    <div class="mx-auto grid max-w-[1280px] grid-cols-1 items-start gap-12 px-5 md:px-10 lg:grid-cols-[1fr_0.9fr] lg:gap-16">
      <div class="reveal order-2 lg:order-1">
        <p class="text-base leading-relaxed text-[var(--color-ink-muted)] md:text-lg">
          {service.body}
        </p>
        <div class="mt-10 flex flex-col gap-3 sm:flex-row">
          <a href="/contact" class="btn btn-primary">Start a project</a>
          <a href="/portfolio" class="btn btn-ghost">View catalog</a>
        </div>
      </div>

      <div class="reveal order-1 overflow-hidden rounded-[var(--radius-card)] border border-[var(--color-chrome)] lg:order-2 lg:sticky lg:top-28">
        <img
          src={serviceImage(service.slug)}
          alt={service.title}
          loading="eager"
          decoding="async"
          class="aspect-[4/3] w-full object-cover"
        />
      </div>
    </div>
  </section>

  <!-- Other services -->
  <section class="on-dark bg-[var(--color-charcoal)] py-20 text-[var(--color-bone)] md:py-24">
    <div class="mx-auto max-w-[1280px] px-5 md:px-10">
      <div class="reveal flex flex-wrap items-end justify-between gap-6">
        <h2 class="text-2xl font-bold tracking-[-0.02em] md:text-3xl">Other services</h2>
        <a href="/our-services" class="btn btn-ghost-dark">All services</a>
      </div>
      <div class="mt-10 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {
          others.map((s) => (
            <a
              href={`/services/${s.slug}`}
              class="reveal group flex flex-col rounded-[var(--radius-card)] border border-white/10 bg-[var(--color-charcoal-2)] p-6 transition-colors hover:border-[var(--color-water)]"
              data-reveal-group="others"
            >
              <h3 class="text-base font-semibold tracking-[-0.01em]">{s.shortTitle}</h3>
              <p class="mt-2 text-sm leading-relaxed text-[var(--color-bone-muted)]">{s.short}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <Reveal />
</Layout>
