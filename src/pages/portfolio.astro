---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import Reveal from "../components/Reveal.astro";
import ProductCard from "../components/ProductCard.astro";
import { products } from "../data/products";

const filters = [
  { key: "all", label: "All" },
  { key: "handles", label: "Handles" },
  { key: "clips", label: "Clips & Clamps" },
  { key: "doors", label: "Doors" },
  { key: "hinges", label: "Hinges" },
];
---

<Layout
  active="portfolio"
  title="Portfolio — Diversity Showers"
  description="Shower hardware catalog: hinges, clips and clamps, handles and sliding doors in five premium finishes."
>
  <PageHero
    eyebrow="[ Our Portfolio ]"
    title="Some of our works and case studies for clients"
    lead="Give a special touch to your bathroom."
  />

  <!-- Filter bar -->
  <section class="sticky top-20 z-30 border-y border-[var(--color-chrome)] bg-[var(--color-light)]/90 backdrop-blur-md">
    <div class="mx-auto flex max-w-[1280px] items-center justify-between gap-4 px-5 py-4 md:px-10">
      <div class="flex flex-wrap gap-2.5" id="filters">
        {
          filters.map((f) => (
            <button
              type="button"
              data-filter={f.key}
              class:list={[
                "filter-pill inline-flex min-h-[40px] items-center rounded-full border px-4 text-sm transition-colors",
                f.key === "all"
                  ? "border-[var(--color-water)] bg-[var(--color-water)] text-white"
                  : "border-[var(--color-chrome)] text-[var(--color-ink-muted)] hover:border-[var(--color-ink)] hover:text-[var(--color-ink)]",
              ]}
            >
              {f.label}
            </button>
          ))
        }
      </div>
      <span class="code hidden shrink-0 text-[var(--color-ink-muted)] sm:block" id="result-count">
        {products.length} ITEMS
      </span>
    </div>
  </section>

  <!-- Grid -->
  <section class="bg-[var(--color-light)] py-16 md:py-24">
    <div class="mx-auto max-w-[1280px] px-5 md:px-10">
      <div class="grid grid-cols-2 gap-5 lg:grid-cols-4" id="product-grid">
        {products.map((p) => <ProductCard product={p} group="cat" />)}
      </div>
      <p class="mt-10 hidden text-center text-[var(--color-ink-muted)]" id="empty-state">
        No products in this category.
      </p>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="on-dark bg-[var(--color-charcoal)] py-20 text-[var(--color-bone)] md:py-24">
    <div class="mx-auto flex max-w-[1280px] flex-col items-start justify-between gap-6 px-5 md:flex-row md:items-center md:px-10">
      <h2 class="max-w-xl text-2xl font-bold tracking-[-0.02em] md:text-3xl">
        Looking for something custom? Let's start a project.
      </h2>
      <a href="/contact" class="btn btn-primary shrink-0">Start a project</a>
    </div>
  </section>

  <Reveal />

  <script>
    const grid = document.getElementById("product-grid");
    const pills = document.querySelectorAll<HTMLButtonElement>(".filter-pill");
    const count = document.getElementById("result-count");
    const empty = document.getElementById("empty-state");
    const cards = grid ? Array.from(grid.children) as HTMLElement[] : [];

    const activeCls = ["border-[var(--color-water)]", "bg-[var(--color-water)]", "text-white"];
    const idleCls = ["border-[var(--color-chrome)]", "text-[var(--color-ink-muted)]"];

    pills.forEach((pill) => {
      pill.addEventListener("click", () => {
        const key = pill.dataset.filter;

        pills.forEach((p) => {
          activeCls.forEach((c) => p.classList.remove(c));
          idleCls.forEach((c) => p.classList.add(c));
        });
        idleCls.forEach((c) => pill.classList.remove(c));
        activeCls.forEach((c) => pill.classList.add(c));

        let shown = 0;
        cards.forEach((card) => {
          const match = key === "all" || card.dataset.category === key;
          card.style.display = match ? "" : "none";
          if (match) shown++;
        });

        if (count) count.textContent = `${shown} ITEMS`;
        if (empty) empty.classList.toggle("hidden", shown > 0);
      });
    });
  </script>
</Layout>
