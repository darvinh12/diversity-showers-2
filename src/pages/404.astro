---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page not found — Diversity Showers">
  <section class="on-dark flex min-h-[80vh] items-center bg-[var(--color-charcoal)] text-[var(--color-bone)]">
    <div class="mx-auto max-w-[1280px] px-5 py-32 text-center md:px-10">
      <span class="code text-[var(--color-water)]">ERROR 404</span>
      <p
        class="mt-4 font-bold leading-none tracking-[-0.05em] text-transparent"
        style="font-size:clamp(5rem,18vw,12rem); -webkit-text-stroke:2px var(--color-water); background:linear-gradient(180deg,rgba(46,127,166,0.18),rgba(46,127,166,0));-webkit-background-clip:text;background-clip:text;"
      >
        404
      </p>
      <h1 class="mt-2 text-[clamp(1.75rem,4vw,2.75rem)] font-bold tracking-[-0.03em]">
        Sorry! Page not found
      </h1>
      <p class="mx-auto mt-4 max-w-md text-base leading-relaxed text-[var(--color-bone-muted)]">
        The page you are looking for does not exist. Let's get you back to where the
        glass is.
      </p>
      <a href="/" class="btn btn-primary mt-8">Take me home</a>
    </div>
  </section>
</Layout>
