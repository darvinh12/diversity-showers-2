---
type Props = {
  eyebrow: string;
  title: string;
  lead?: string;
};
const { eyebrow, title, lead } = Astro.props;
---

<section class="on-dark bg-[var(--color-charcoal)] pt-32 pb-16 text-[var(--color-bone)] md:pt-40 md:pb-20">
  <div class="mx-auto max-w-[1280px] px-5 md:px-10">
    <span class="eyebrow">{eyebrow}</span>
    <h1 class="mt-5 max-w-4xl text-[clamp(2rem,5vw,3.75rem)] font-bold leading-[1.05] tracking-[-0.03em]">
      {title}
    </h1>
    {
      lead && (
        <p class="mt-6 max-w-2xl text-base leading-relaxed text-[var(--color-bone-muted)] md:text-lg">
          {lead}
        </p>
      )
    }
    <slot />
  </div>
</section>
