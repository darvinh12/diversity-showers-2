---
// Drop once per page. Reveals every .reveal element when it enters the viewport,
// staggering siblings that share [data-reveal-group]. IntersectionObserver-based
// (independent of GSAP/Lenis) so content is reliable; respects reduced motion.
---

<script>
  const els = Array.from(document.querySelectorAll<HTMLElement>(".reveal"));
  if (els.length) {
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const showAll = () => els.forEach((el) => el.classList.add("is-in"));

    if (reduced || !("IntersectionObserver" in window)) {
      showAll();
    } else {
      // Track per-group stagger order so siblings cascade in.
      const groupCount = new Map<string, number>();

      const io = new IntersectionObserver(
        (entries, obs) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            const el = entry.target as HTMLElement;
            const g = el.dataset.revealGroup;
            // Stagger only the first few siblings; cap so a fast scroll never
            // leaves later items waiting behind a long cascade.
            const i = g ? Math.min(groupCount.get(g) ?? 0, 5) : 0;
            if (g) groupCount.set(g, (groupCount.get(g) ?? 0) + 1);
            window.setTimeout(() => el.classList.add("is-in"), i * 60);
            obs.unobserve(el);
          }
        },
        { rootMargin: "0px 0px 0px 0px", threshold: 0.05 },
      );

      els.forEach((el) => io.observe(el));

      // Safety net: anything still hidden after 3s gets shown.
      window.setTimeout(showAll, 3000);
    }
  }
</script>
