---
import { site } from "../lib/site";
import { services } from "../data/services";
import Logo from "./Logo.astro";

const year = 2026;
const footerServices = services.slice(0, 6);

const socials = [
  { label: "Instagram", href: site.social.instagram },
  { label: "Pinterest", href: site.social.pinterest },
  { label: "LinkedIn", href: site.social.linkedin },
];
---

<footer class="on-dark bg-[var(--color-charcoal)] text-[var(--color-bone)]">
  <div class="mx-auto max-w-[1280px] px-5 py-16 md:px-10 md:py-20">
    <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <!-- Brand + social -->
      <div>
        <Logo />
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-[var(--color-bone-muted)]">
          Custom tempered-glass shower doors, mirrors and railings — designed and
          installed across the DFW Metroplex.
        </p>
        <div class="mt-6 flex gap-3">
          {
            socials.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/15 text-[var(--color-bone-muted)] transition-colors hover:border-[var(--color-water)] hover:text-[var(--color-bone)]"
                aria-label={s.label}
              >
                <span class="font-mono text-[10px] font-bold uppercase">{s.label.slice(0, 2)}</span>
              </a>
            ))
          }
        </div>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="eyebrow eyebrow--bone">Contact Us</h3>
        <ul class="mt-5 space-y-3 text-sm text-[var(--color-bone-muted)]">
          <li>{site.address.line1}<br />{site.address.line2}</li>
          <li><a href={`mailto:${site.email}`} class="transition-colors hover:text-[var(--color-bone)]">{site.email}</a></li>
          <li><a href={`tel:${site.phones.office.replace(/\s/g, "")}`} class="transition-colors hover:text-[var(--color-bone)]">{site.phones.office}</a></li>
          <li><a href={`tel:${site.phones.cell.replace(/\s/g, "")}`} class="transition-colors hover:text-[var(--color-bone)]">{site.phones.cell}</a></li>
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="eyebrow eyebrow--bone">Our Services</h3>
        <ul class="mt-5 space-y-3 text-sm text-[var(--color-bone-muted)]">
          {
            footerServices.map((s) => (
              <li>
                <a href={`/services/${s.slug}`} class="transition-colors hover:text-[var(--color-bone)]">
                  {s.shortTitle}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Need help -->
      <div>
        <h3 class="eyebrow eyebrow--bone">Need Help?</h3>
        <p class="mt-5 text-sm text-[var(--color-bone-muted)]">
          Have a question? Get in touch with us.
        </p>
        <a href="/contact" class="btn btn-ghost-dark mt-5">Get in touch</a>
      </div>
    </div>

    <div class="mt-14 flex flex-col items-start justify-between gap-4 border-t border-white/10 pt-7 text-xs text-[var(--color-bone-muted)] sm:flex-row sm:items-center">
      <p>© {year} {site.legalName}. All Rights Reserved.</p>
      <div class="flex gap-6">
        <a href="/terms-of-use" class="transition-colors hover:text-[var(--color-bone)]">Terms of Use</a>
        <a href="/privacy-policy" class="transition-colors hover:text-[var(--color-bone)]">Privacy Policy</a>
      </div>
    </div>
  </div>
</footer>
